# ── OpenAI (필수) ─────────────────────────────────────────
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-proj-...

# ── Tavily Search (필수: 트렌드 검색) ────────────────────
# https://tavily.com → 무료 1,000회/월
TAVILY_API_KEY=tvly-...

# ── Pexels (선택: 실사 배경 사진) ────────────────────────
# https://www.pexels.com/api → 무료, 즉시 발급
PEXELS_API_KEY=

# ── Instagram Graph API (선택: 자동 업로드) ───────────────
# 설정 가이드: src/agents/publisher.py 상단 주석 참고
# 1. https://developers.facebook.com 에서 앱 생성
# 2. Instagram 비즈니스/크리에이터 계정 연결
# 3. 아래 3개 항목 입력
IG_ACCESS_TOKEN=EAAxxxxxxxx...
IG_USER_ID=17841xxxxxxxxx
# 이미지 공개 URL (ngrok/Cloudflare Tunnel/S3 중 택1)
# 예: https://abc123.ngrok-free.app/output/2026-03-24_AI트렌드
IG_IMAGE_BASE_URL=

# ── Threads (선택: Threads 동시 발행) ────────────────────
# Instagram 계정과 연결된 Threads API
# IG_ACCESS_TOKEN과 동일한 토큰을 사용하면 됩니다
THREADS_ACCESS_TOKEN=EAAxxxxxxxx...
THREADS_USER_ID=

# ── 블로그 (선택: 블로그 자동 포스팅) ────────────────────
# 티스토리: https://www.tistory.com/guide/api/manage/register
TISTORY_ACCESS_TOKEN=
TISTORY_BLOG_NAME=

# 네이버 블로그: https://developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_ACCESS_TOKEN=

# ── 텔레그램 봇 (선택: 폰으로 승인/알림) ────────────────
# 1. @BotFather 에서 /newbot → 토큰 발급
# 2. 봇에 메시지 전송 후 https://api.telegram.org/bot<TOKEN>/getUpdates 로 Chat ID 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 파이프라인 기본 설정 ──────────────────────────────────
DEFAULT_TOPIC=AI 트렌드
NUM_CARDS=6
OUTPUT_DIR=output
